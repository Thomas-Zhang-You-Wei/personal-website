# ── Node / Frontend ───────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log

# ── Editor ────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
._*
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/

# ── 敏感資料：絕對不 commit ──────────────────────────────────────────
# 環境變數（含 SECRET_KEY、資料庫密碼）
.env
.env.*
!.env.example

# 自動產生的 secret key（等同於私鑰）
backend/.secret_key

# 資料庫（含用戶帳號、密碼 hash、留言內容）
*.db
*.sqlite
*.sqlite3

# 用戶上傳的頭貼（個人資料）
backend/uploads/*
!backend/uploads/.gitkeep

# 私鑰 / TLS 憑證
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519

# ── Claude Code 內部目錄 ──────────────────────────────────────────────
.claude/

# ── 本地分析報告（不需要進 repo）─────────────────────────────────────
ATTACK_LOG*.md
TEST_SUMMARY*.md
SECURITY_AUDIT*.md
SECURITY_CHECKLIST*.md
